# Stage 1 - Build ASP.NET Web API

FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /app
COPY \*.csproj ./
RUN dotnet restore
COPY . .
RUN dotnet publish -c Release -o /out

# Stage 2 - Run

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /out .
EXPOSE 80
EXPOSE 443
ENTRYPOINT ["dotnet", "TaskManager.dll"]
